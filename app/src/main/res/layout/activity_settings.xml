<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/window_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_color"
        app:title="@string/settings_title"
        app:titleTextColor="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:navigationIconTint="@color/white" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- API设置区域 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/api_settings"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color" />

                    <!-- 语音识别引擎选择 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/speech_provider"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgSpeechProvider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbSenseVoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/speech_sensevoice"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rbWhisper"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/speech_whisper" />

                        <RadioButton
                            android:id="@+id/rbAnimeWhisper"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/speech_anime_whisper" />
                    </RadioGroup>

                    <!-- 语音识别 API Key -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/speech_api_key_label"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSpeechApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/translation_provider"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- 翻译服务提供商选择 -->
                    <RadioGroup
                        android:id="@+id/rgTranslationProvider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbLibreTranslate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_libre" />

                        <RadioButton
                            android:id="@+id/rbGoogleTranslate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_google" />

                        <RadioButton
                            android:id="@+id/rbDeepSeek"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_deepseek"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rbKimi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_kimi" />
                    </RadioGroup>

                    <!-- 翻译 API Key -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="@string/translation_api_key_label"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTranslationApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvApiKeyHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="选择DeepSeek或Kimi时需要填写对应API Key，LibreTranslate免费无需Key"
                        android:textSize="12sp"
                        android:textColor="@android:color/darker_gray" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 外观设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appearance_settings"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color" />

                    <!-- 显示模式 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/display_mode"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <RadioGroup
                        android:id="@+id/rgDisplayMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbBilingual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/display_bilingual"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rbChineseOnly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/display_chinese_only" />

                        <RadioButton
                            android:id="@+id/rbJapaneseOnly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/display_japanese_only" />
                    </RadioGroup>

                    <!-- 字体大小滑块 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/subtitle_font_size"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <SeekBar
                        android:id="@+id/sliderFontSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="32"
                        android:progress="16" />

                    <!-- 背景不透明度 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="背景透明度"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <SeekBar
                        android:id="@+id/sliderOpacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="80" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 保存按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="@string/save"
                android:textSize="16sp"
                app:cornerRadius="28dp"
                app:backgroundTint="@color/primary_color" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
